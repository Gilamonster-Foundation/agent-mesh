__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# Maturin / wheel outputs
dist/
# Native extension dropped in-place by `maturin develop`.
agent-mesh-py/python/agent_mesh/*.so
